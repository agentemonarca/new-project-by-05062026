# Clave admin (mismo valor que GENESIS_ADMIN_API_KEY en backend/core-api/.env). El bundle usa VITE_GENESIS_ADMIN_API_KEY.
# VITE_GENESIS_ADMIN_API_KEY=
# Alias opcional (documentación / scripts): GENESIS_ADMINgpulse_API_KEY=

# GPulse Lab — middleware de correlación: en ControlPanel queda ON por defecto (sin clave en localStorage
# `gpulse_lab_middleware_enabled`); el usuario puede apagarlo y se guarda la preferencia.

# GPulse Lab: botón "Simular ciclo" en ControlPanel (local fake). Producción: 0 (solo proveedor real).
VITE_GPULSE_ALLOW_LAB_SIMULATE=0

# Consola: 🔥 EVENT: NEW_SIGNAL / NEW_RESULT al recibir del namespace /admin-signals
# VITE_ADMIN_SIGNALS_SOCKET_EVENT_LOG=1

# 🧠 TIMING CHECK: now vs serverTs/createdAt (detectar replay en bloque vs mesa real ~10–20s)
# VITE_GPULSE_TIMING_CHECK_LOG=1

# Phase 7 — log ENGINE EVENT / ENGINE STATE, duplicate-process and render-loop checks
VITE_GPULSE_FLICKER_FORENSIC=1

# Phase 1 — console: TEST PHASE 1 - SIGNAL RECEIVED / ENGINE CREATED on NEW_SIGNAL
# VITE_GPULSE_PHASE1_TEST=1

# Phase 2 — console: TEST PHASE 2 - RESULT RECEIVED / ENGINE AFTER RESULT on NEW_RESULT
# VITE_GPULSE_PHASE2_TEST=1

# Phase 3 — console: DEDUP CHECK before NEW_RESULT step+ganador dedupe
# VITE_GPULSE_PHASE3_TEST=1
