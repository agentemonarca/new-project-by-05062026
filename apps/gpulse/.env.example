# --- Security (read this) ---
# Vite only exposes variables prefixed with VITE_ to the client (import.meta.env).
# NEVER use the VITE_ prefix for private keys, seed phrases, or server-only secrets.
#
# Crear `.env` en esta carpeta:
#   npm run init:env
#   (o manualmente: cp .env.example .env)
# Do not commit `.env`.
# If a PRIVATE_KEY or similar was ever pushed to git, rotate it immediately.
#
# Dev: `npm run dev` en esta app → http://localhost:5174 (vite.config fija 5174 + strictPort).
#      No uses el 5173 “por defecto de Vite” salvo que cambies el puerto a mano.

# Web3: mock (default) = emulador · real = wallet inyectada (MetaMask). Requiere contrato/red para transferencias.
# VITE_WEB3_MODE=mock
# VITE_WEB3_MODE=real

# G_Pulse Web3 — ERC-20 USDT (misma red que el contrato)
# Ejemplo Ethereum mainnet USDT (verifica la dirección oficial en la red que uses):
# VITE_USDT_CONTRACT=0xdAC17F958D2ee523a2206206994597C13D831ec7
# VITE_RECEIVER_WALLET=0xTuWalletDeCobro
# VITE_CHAIN_ID=1

VITE_USDT_CONTRACT=
VITE_RECEIVER_WALLET=
VITE_CHAIN_ID=

# G_Pulse Web3 — deposit receiver (source of truth for REAL mode deposits)
VITE_MASTER_WALLET_ADDRESS=

# Backend API base URL (Railway example — no trailing slash)
# VITE_API_URL=https://YOUR_BACKEND_URL.up.railway.app
# Prefer VITE_API_URL; VITE_BACKEND_URL is still supported for older configs.
VITE_API_URL=
VITE_BACKEND_URL=

# Login operador (UI: /admin/login en esta app → cookie de sesión vía proxy /api).
# Credenciales solo en backend: backend/core-api/.env → ADMIN_EMAIL y ADMIN_PASSWORD (no VITE_).

# Set to 1 to load the Genesis design preview (ui-genesis) instead of the main G-Pulse shell
# VITE_GENESIS_UI=1
# 1 = opening `/` redirects to Genesis Command Center backoffice (`/admin` → overview; login `/admin/login`)
# VITE_GENESIS_BACKOFFICE_HOME=0
# 1 = if BACKOFFICE_HOME is off, `/` can open Genesis Dashboard (`/dashboard`). Main G-Pulse: `/gpulse`
# VITE_GENESIS_DASHBOARD_HOME=0
# Shortcuts: `/backoffice` and `/genesis-admin` → `/admin` (same as `/admin-core` mirror)

# Shell principal (App.jsx): IA_REAL | SIMULACION | VISOR — default recomendado con stream real: IA_REAL
# VITE_GPULSE_DEFAULT_MODE=IA_REAL
# 1 = ocultar botón «Simular» (solo Visor + IA Real). Omitir o 0 para que usuarios usen modo simulación (fondos virtuales).
# VITE_GPULSE_HIDE_SIM_MODE=0

# 1 (default): shell solo IA Real + sin motor local (fases/martingala) — solo NEW_SIGNAL / NEW_RESULT del relay.
# 0 = restaurar scheduler local y loop T1–T6 (solo dev/legacy).
# VITE_GPULSE_REAL_PROVIDER_EXECUTION=1
# 1 = consola: 🔍 RNG CHECK en cada rngCheck() (política Math.random)
# VITE_GPULSE_RNG_AUDIT=0
# 1 = end-to-end trace: console + POST to core-api (merge into debug/provider-full-flow.json with ADMIN_SIGNALS_FULL_FLOW=1)
# VITE_GPULSE_FULL_FLOW=0
# 1 = consola: DEBUG RESULT INPUT / DEBUG STORE UPDATE (martingala merge en externalSignalsStore)
# VITE_DEBUG_MG=0
# 1 = auditoría pipeline: socket RAW → NORMALIZED → STORE → UI (useExternalSignals, externalSignalsStore, IaRealExecutionLayer)
# VITE_CYCLE_DEBUG=0
# 1 = consola: 🧾 RAW RESULT FRONT + extractMesaInfoFlexible (IaRealExecutionLayer; sin activar todo CYCLE_DEBUG)
# VITE_DEBUG_IA_RESULT_FRONT=0
# 1 = consola: 🧾 RAW RESULT / META / THEATER flags en IaRealCardTheater (mismo efecto que RESULT_FRONT si se prefiere solo teatro)
# VITE_DEBUG_IA_CARD_THEATER=0
# 1 = PIPE CHECK (socket/store/ui) + console.table salud IA Real (VITE_IA_REAL_PIPE_CHECK)
# VITE_IA_REAL_PIPE_CHECK=0
# 1 = console.table({ history, wins, losses, distribution }) desde extHistory (IA Real shell)
# VITE_IA_REAL_HISTORY_TABLE=0
# 1 = DEV: console.table variables env relevantes + modo + store señales (~3s tras carga)
# VITE_GPULSE_RUNTIME_AUDIT=0
# 1 = auditoría «datos reales vs mock»: Fase1 console.table ENV, Fase2 RAW SOCKET + contadores, Fase3 HISTORY/pipeline, Fase4 rawResult/cartas, Fase5 ledger+wallet, Fase6–7 tabla estática (ver `src/utils/gpulseRealityAudit.js`)
# VITE_GPULSE_REALITY_AUDIT=0
# 1 = panel fijo ProviderAuditPanel (raw relay + store + iaRealEngineState + fase UI)
# VITE_DEBUG_AUDIT_PANEL=0
# 1 = arrancar siempre en IA Real (resolveUiDefaultMode). No oculta «Simular»; para eso usa VITE_GPULSE_HIDE_SIM_MODE=1.
# VITE_GPULSE_FORCE_IA_REAL=0
# 1 (default): bloquear modo simulación Genesis (dataset ficticio en dashboard).
# VITE_GPULSE_DISABLE_SIMULATION_MODE=1

# Install deps from monorepo root: pnpm install (required for workspace:* packages)

# Verbose [genesis-api] console logs in dev (set to 0 to silence)
# VITE_DEBUG_API=1

# Dev only: log API base + genesis proxy hint + web3 boot (default: silent console)
# VITE_VERBOSE_BOOT=1

# Hide the floating mock-Web3 dev panel (“MOCK MODE” corner widget). Does not affect TronLink extension logs.
# VITE_HIDE_MOCK_WEB3_PANEL=1

# Genesis UI — optional JWT from core-api for dev when SIWE is skipped (never commit real tokens)
# VITE_DEV_MOCK_BEARER=

# P2P: debe ser el string exacto "true" para usar core-api (/api/p2p/*). Cualquier otro valor → demo en memoria.
VITE_P2P_USE_BACKEND=true

# Simulate purchase/deposit in Genesis dashboard (no chain)
# VITE_SIMULATE_DEPOSIT=1

# Mock mode injected-provider isolation (Tron globals + optional ethereum hide). Set to 1 to disable all shielding.
# VITE_DISABLE_MOCK_INJECTED_ISOLATION=1
# Tron only: skip Tron key shield (same as legacy name). Ethereum isolation may still apply unless disabled above.
# VITE_DISABLE_TRON_SHIELD=1
# Allow real window.ethereum to exist in mock mode (default: hidden / undefined for strict isolation).
# VITE_MOCK_ALLOW_INJECTED_ETHEREUM=1

# Dev: structured mount/update traces + undefined/NaN/array/callback watchers (requires import.meta.env.DEV).
# VITE_DEBUG_RUNTIME_TRACE=1

# Socket.io origin (default: same as VITE_BACKEND_URL)
# VITE_SOCKET_URL=http://localhost:5050

# --- Señales externas Baccarat (Socket.IO + auth apiKey) — ver ui-genesis/hooks/useExternalSignals.js
# Activa el tablero y el socket solo con:
# VITE_EXTERNAL_SIGNALS_ENABLED=1
# Misma clave que GENESIS_ADMIN_API_KEY (core-api). Se envía en header si está definida (local/staging/prod con cuidado).
# VITE_GENESIS_ADMIN_API_KEY=
# Opcional (alias documental / scripts; el cliente Vite usa solo VITE_GENESIS_ADMIN_API_KEY):
# GENESIS_ADMINgpulse_API_KEY=
# Logs [adminSignalsFetch] en consola del navegador
# VITE_ADMIN_SIGNALS_DEBUG=1

# --- Datos reales vs demo (Baccarat / VistaLab / Oracle)
# El navegador solo habla con TU core-api (`/admin-signals`). El servidor necesita en backend/core-api/.env:
#   EXTERNAL_SIGNALS_API_KEY=<clave proveedor Winxplay>  (obligatoria para que arranque el bridge upstream)
#   EXTERNAL_SIGNALS_WS=wss://.../external-signals       (opcional; si falta usa default del código)
#   GPULSE_DEMO_MODE=0                                  (no forzar motor demo en servidor)
#   ADMIN_SIGNALS_TEST_EMIT_ALWAYS=0 y ADMIN_SIGNALS_TEST_EMIT_MS=0  (sin señales sintéticas de prueba)
# Web3 wallet sigue en mock en esta app salvo integración futura; es independiente del stream de mesas.
#
# Relay seguro vía core-api (apiKey solo servidor): admin namespace /admin-signals + proxy Vite /socket.io
# VITE_EXTERNAL_SIGNALS_BFF=1
# URL por defecto: wss://appserver.winxplay.io:3000/external-signals (namespace)
# VITE_EXTERNAL_SIGNALS_URL=wss://appserver.winxplay.io:3000/external-signals
# NO uses VITE_* con clave real en prod: expone al bundle; usa proxy backend o sessionStorage gpulse_external_signals_key (solo dev)
# VITE_EXTERNAL_SIGNALS_API_KEY=

# Use POST /api/request-withdraw { async: true } for queued withdrawals (requires Redis + worker)
# VITE_WITHDRAW_ASYNC=true
