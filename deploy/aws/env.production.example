# Copiar a AWS Secrets Manager / SSM Parameter Store / task definition secrets.
# NO commitear valores reales.

NODE_ENV=production
PORT=5050

# MongoDB: URI de replica set (DocumentDB, Atlas o auto-hospedado en EC2)
# Formato replica set: mongodb://user:pass@host1:27017,host2:27017,host3:27017/genesis?replicaSet=rs0&tls=true
MONGO_URI=

# Seguridad sesión / cookies (obligatorio rotar en prod)
SESSION_SECRET=
SESSION_COOKIE_SECURE=1

# Genesis admin (operaciones, auditoría, export)
GENESIS_ADMIN_API_KEY=

# Prometheus scrape dedicado (misma clave en scrape_configs.authorization.credentials)
GENESIS_PROMETHEUS_SCRAPE_TOKEN=

# Transacciones ACID multi-documento: DocumentDB y Mongo 4+ con replica set → dejar vacío
# Solo standalone local: GENESIS_DISABLE_MONGO_TRANSACTIONS=1
GENESIS_DISABLE_MONGO_TRANSACTIONS=

# CORS / Socket (origen del frontend en prod)
SOCKET_CORS_ORIGIN=https://app.tudominio.com

# Redis (BullMQ) si aplica
# REDIS_URL=rediss://...

# Otros servicios del core-api según .env.example del proyecto
