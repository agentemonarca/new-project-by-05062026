{
  "agent": {
    "metrics_collection_interval": 60,
    "run_as_user": "root"
  },
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/g-pulse-core-api/app.log",
            "log_group_name": "/aws/ec2/g-pulse-core-api",
            "log_stream_name": "{instance_id}/app",
            "timezone": "UTC"
          }
        ]
      }
    }
  },
  "metrics": {
    "namespace": "GPulse/EC2",
    "metrics_collected": {
      "disk": { "measurement": [{ "name": "used_percent", "rename": "DiskUsedPercent", "unit": "Percent" }] },
      "mem": { "measurement": [{ "name": "mem_used_percent", "rename": "MemoryUsedPercent", "unit": "Percent" }] }
    }
  }
}
