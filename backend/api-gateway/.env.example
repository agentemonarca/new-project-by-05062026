PORT=4000
CORE_API_URL=http://127.0.0.1:5050
GPULSE_API_URL=http://127.0.0.1:5052
# Required for POST /webhooks/gpulse (503 if unset)
WEBHOOK_SECRET=change-me-in-production
# Optional: WEBHOOK_RATE_LIMIT_PER_MINUTE=30
# Optional: WEBHOOK_IDEMPOTENCY_MAX_IDS=5000
# Optional: WEBHOOK_IDEMPOTENCY_TTL_MS=600000
# Optional: TRUST_PROXY=1 (accurate client IP behind one proxy)
# Optional: when set, /api/* requires Authorization: Bearer <jwt>
# JWT_SECRET=
LOG_LEVEL=info
# Forward POST /webhooks/compensation/ingest → core-api (optional)
# COMPENSATION_INGEST_SECRET=match-incoming-X-Webhook-Secret
# Must match core-api COMPENSATION_WEBHOOK_SECRET
# COMPENSATION_WEBHOOK_SECRET=
