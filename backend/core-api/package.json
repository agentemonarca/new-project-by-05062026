{
  "name": "@ai-genesis/core-api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build:db": "tsc -p tsconfig.db.json",
    "build:compensation": "tsc -p tsconfig.compensation.json",
    "prestart": "npm run build:db && npm run build:compensation",
    "dev": "npm run build:db && npm run build:compensation && node --watch src/server.js",
    "dev:multi": "npm run build:db && npm run build:compensation && node src/server.js",
    "dev:clean": "sh -c 'for pid in $(lsof -ti :5050 2>/dev/null); do kill -9 \"$pid\" 2>/dev/null || true; done'",
    "start": "node src/server.js",
    "worker:tx": "node src/workers/txWorker.js",
    "typecheck:compensation": "tsc -p tsconfig.compensation.json --noEmit",
    "test:payout": "npm run build:compensation && node --test tests/payoutIdempotency.test.js",
    "mongo:inspect": "node scripts/mongo-inspect.mjs",
    "analyze:provider-stream": "node provider-stream-analyze-120s.mjs",
    "capture:one-signal-session": "node capture-one-signal-session.mjs",
    "capture:sequential-sessions": "node capture-sequential-signal-sessions.mjs",
    "capture:mesa-radiograph": "node mesa-session-radiograph.mjs",
    "capture:3-sessions-forensic": "node capture-3-sessions-forensic.mjs"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/express-session": "^1.18.2",
    "@types/node": "^22.19.15",
    "axios": "^1.14.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "bullmq": "^5.34.5",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "ethers": "^6.16.0",
    "express": "^4.19.2",
    "express-session": "^1.19.0",
    "ioredis": "^5.4.2",
    "mongoose": "^8.9.5",
    "siwe": "^3.0.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1"
  }
}
