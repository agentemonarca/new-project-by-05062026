# Primary RPC (used if RPC_URLS not set)
RPC_URL=
# Comma-separated RPC endpoints — fastest healthy used for on-chain ops
RPC_URLS=
MASTER_WALLET_ADDRESS=
PRIVATE_KEY=
CHAIN_ID=1
PORT=5050

# MongoDB — URL-encode special chars in password (e.g. $ → %24).
# Conexiones nombradas (mongoose.createConnection, sin conexión global):
#   genesis  — P2P + persistencia admin-signals (escritura). Obligatoria para el stack completo.
#   winx     — opcional; lecturas admin `?source=winx`
#   gpulse   — opcional; lecturas admin `?source=gpulse`
# MONGO_URI_GENESIS=   (opcional; si no existe se usa MONGO_URI)
# MONGO_URI=mongodb://user:encodedpass@host:27017/genesis
# MONGO_URI_WINX=mongodb://user:encodedpass@host:27017/winx
# MONGO_URI_GPULSE=mongodb://user:encodedpass@host:27017/gpulse
# Diagnóstico: desde backend/core-api → npm run mongo:inspect (lista colecciones, conteos, 3 muestras/colección)
# Optional: seed ~20 docs in signal_events if collection empty (dev only)
# MONGO_SEED_ADMIN_SIGNALS=0
# Delay (ms) before mongo verify + HTTP smoke after listen (default 800)
# MONGO_STARTUP_VERIFY_DELAY_MS=800

# --- SIWE (EIP-4361) cookie sessions — /auth/nonce, /auth/verify, /auth/logout
# Strong secret for express-session (required in production)
# SESSION_SECRET=
# Set SESSION_COOKIE_SECURE=1 behind HTTPS (or NODE_ENV=production defaults to secure cookies)
# SESSION_COOKIE_SECURE=
# Optional: fixed DNS authority if Host / X-Forwarded-Host don’t match the client (must equal SiweMessage.domain)
# SIWE_DOMAIN=localhost:5174
# Optional: comma-separated allowed origins for siwe.uri + Origin / Referer checks (recommended in production)
# SIWE_ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174
# Nonce TTL (ms), default 600000 (10 minutes); min 30000, max 3600000
# SIWE_NONCE_TTL_MS=600000

# Redis — required for async withdrawal queue + shared cache TTL
REDIS_URL=

# BullMQ withdrawal pipeline (disable with GPULSE_TX_QUEUE_DISABLED=1)
GPULSE_TX_QUEUE_DISABLED=
# Run worker inside API process (dev only; prod: npm run worker:tx)
RUN_INLINE_TX_WORKER=
TX_WORKER_CONCURRENCY=2

# Default async API: set GPULSE_DEFAULT_ASYNC_WITHDRAW=1 so all withdraws enqueue without body.async
GPULSE_DEFAULT_ASYNC_WITHDRAW=

# Queue recovery: refund QUEUED rows older than this (ms)
WITHDRAW_QUEUE_STALE_MS=3600000

# HTTP caching + socket
HEALTH_CACHE_TTL_MS=8000
SYSTEM_HEALTH_BROADCAST_MS=12000
# Socket.io `queue:stats` broadcast interval (ms); set 0 to disable
QUEUE_STATS_BROADCAST_MS=8000
# Dev: *  ·  Producción: orígenes separados por coma (nunca '*'); si falta en prod, Socket.IO CORS queda deshabilitado.
SOCKET_CORS_ORIGIN=*

# --- Admin Signals BFF (relay Socket.IO proveedor externo → /admin-signals)
# Caso A (sin clave): relay Winxplay desactivado; por defecto emite NEW_SIGNAL de prueba cada 5s (panel siempre ve algo).
# Caso D: si [EMIT CHECK] clients=0 → abre admin-core /admin/signals con VITE_GENESIS_ADMIN_API_KEY + proxy /socket.io al API.
# Clave nunca en el bundle del browser; solo core-api.
# EXTERNAL_SIGNALS_API_KEY=
# Ejemplo Winxplay / proveedor (ajustar al entorno real):
# EXTERNAL_SIGNALS_API_KEY=tu_clave_proveedor
# WINXPLAY_DEBUG_STREAM=1
# ↑ Si está activo, cada dashboardUpdate del upstream emite `DEBUG_STREAM` en el namespace /admin-signals (solo operadores conectados).
# Preferencia: URL del socket proveedor (socket.io-client). Si vacío, usa EXTERNAL_SIGNALS_URL.
# EXTERNAL_SIGNALS_WS=wss://appserver.winxplay.io:3000/external-signals
# Alias legacy:
# EXTERNAL_SIGNALS_URL=wss://appserver.winxplay.io:3000/external-signals
# Trazas JSON en consola: [admin-signals-flow] … (upstream → processor → mongo → socket emit)
# ADMIN_SIGNALS_DEBUG_FLOW=1
# Log de cada nombre de evento recibido del proveedor (verbose)
# ADMIN_SIGNALS_LOG_UPSTREAM_EVENTS=1
# Primera muestra JSON por tipo (dashboardUpdate | NEW_SIGNAL | NEW_RESULT), una vez por proceso. Ver docs/admin-signals-winxplay-fields.md
# ADMIN_SIGNALS_LOG_RAW_PROVIDER_SAMPLE=1
# Emisión local de prueba al namespace /admin-signals (ms). 0 = desactivar. Si EXTERNAL_SIGNALS_API_KEY existe y quieres TEST además de Winxplay:
# Test emit al panel /admin-signals (sin depender del proveedor). Por defecto en código: ALWAYS=1, MS=3000 si no se define.
# Desactivar: ADMIN_SIGNALS_TEST_EMIT_ALWAYS=0 o ADMIN_SIGNALS_TEST_EMIT_MS=0
ADMIN_SIGNALS_TEST_EMIT_ALWAYS=1
ADMIN_SIGNALS_TEST_EMIT_MS=3000
# POST/GET /api/admin/signals/config · GET /api/admin/signals/stats · GET /api/admin/signals/metrics
# Persistencia Mongo (MONGO_URI requerido): collections signal_config, signal_events, signal_metrics
# ADMIN_SIGNALS_CONFIG_RATE_LIMIT_PER_MIN=40
# GETs y mutaciones signals (cubo propio, alto): peticiones / min por IP (default dev 1200, prod 400)
# ADMIN_SIGNALS_READ_RATE_LIMIT_PER_MIN=400

# --- Rate limits HTTP (cubos separados)
# API general (todo /api salvo admin auth, admin session, admin signals): max por ventana (default dev 2500, prod 600 en 15 min)
# API_GENERAL_RATE_LIMIT_MAX=600
# API_GENERAL_RATE_LIMIT_WINDOW_MS=900000
# SIWE cartera: /api/auth/request-message y verify-signature (default dev 2000/5 min, prod 10/5 min)
# API_AUTH_WALLET_REQUEST_MESSAGE_MAX=10
# API_AUTH_WALLET_VERIFY_MAX=10

# Compensation engine (TypeScript build: npm run build:compensation)
# COMPENSATION_ENABLED=1
# COMP_WHITELIST=0xabc...,0xdef...
# COMP_DIRECT_BONUS=0.11
# COMP_BINARY_BONUS=0.11
# COMP_ROI_MONTHLY=0.11
# COMP_ROI_CAP=2.5
# COMP_MIN_WITHDRAW=50
# COMP_SECONDS_PER_ROI_MONTH=2592000
# Native payout: wei paid per 1.0 USDT notional (ledger USDT maps to native wei at this rate)
# COMP_PAYOUT_WEI_PER_USDT=1000000000000000
# Optional bounds (re-read on each payout; dynamic env updates OK)
# COMP_PAYOUT_WEI_PER_USDT_MIN=1
# COMP_PAYOUT_WEI_PER_USDT_MAX=1000000000000000000000000
#
# Deposits: native coin vs ERC-20 (e.g. USDT). Native uses parseEther on `amount`; erc20 uses parseUnits(..., DEPOSIT_TOKEN_DECIMALS).
# DEPOSIT_ASSET=native
# DEPOSIT_ASSET=erc20
# DEPOSIT_TOKEN_ADDRESS=
# DEPOSIT_TOKEN_DECIMALS=6
#
# Webhook POST /api/webhooks/compensation — prefer HMAC: X-Comp-Signature: t=<unixSeconds>,v1=<hex_hmac_sha256>
# Payload signed: `${t}.${rawBody}` with secret COMPENSATION_WEBHOOK_SECRET
# COMPENSATION_WEBHOOK_SECRET=
# Migration only (disable in prod): COMPENSATION_WEBHOOK_ALLOW_PLAIN_SECRET=1 plus header X-Compensation-Webhook-Secret
# COMPENSATION_WEBHOOK_MAX_SKEW_MS=300000
# COMPENSATION_WEBHOOK_REQUIRE_PROCESSED_DEPOSIT_TX=1
# COMPENSATION_WEBHOOK_RATE_LIMIT_PER_MIN=40
#
# Durable compensation snapshot (automatic): data/compensationState.json

# api-gateway: POST /webhooks/compensation/ingest forwards to core (optional)
# COMPENSATION_INGEST_SECRET=

# --- Genesis platform API (cuando COMPENSATION_ENABLED ≠ 1 o el kernel no arranca)
# Con MONGO_URI el core-api persiste users, órdenes P2P y transacciones (colecciones genesis_* / p2p_*).
# GENESIS_USE_EMPTY_MOCK=1  → /api/wallet|earnings|network como antes (vacío)
# P2P_SKIP_MINING_CHECK=1   → permitir órdenes de venta sin miningActive (solo dev)
# Clave para /api/admin/genesis/*, /api/admin/audit/run, /api/ledger/export (bypass de sesión con X-Admin-Api-Key)
# GENESIS_ADMIN_API_KEY=
# Login admin UI (POST /api/admin/auth/login) — sesión express-session (cookie httpOnly gpulse.sid); no poner en Vite
# ADMIN_EMAIL=
# ADMIN_PASSWORD=
# Transacciones multi-documento Mongo (réplica). Standalone o diagnóstico: GENESIS_DISABLE_MONGO_TRANSACTIONS=1
# GENESIS_DISABLE_MONGO_TRANSACTIONS=
# Auditoría drift: POST /api/admin/audit/run { userId?, maxUsers? } · export ledger GET /api/ledger/export?limit=&userId=&sinceTs=
# Observabilidad (admin key): GET /api/admin/genesis/observability/dashboard · GET /api/admin/genesis/observability/prometheus
# Métricas scrape (prod): GENESIS_PROMETHEUS_SCRAPE_TOKEN + GET /api/metrics/genesis (Bearer o X-Genesis-Metrics-Token)
# Logs JSON: msg=genesis_structured (domain, event) | metric genesis_* | AUDIT_DRIFT_CRITICAL | GENESIS_CRITICAL_FAILURE
# GENESIS_PROMETHEUS_SCRAPE_TOKEN=
# Wallet unificado: balances.{usd,aig} en genesis_users · GET /api/wallet/unified · GET /api/wallet (incl. bloque unified)
# Rewards: GET /api/rewards · POST /api/rewards/claim · GET /api/rewards/history · GET /api/ledger/events?reconcile=1 | reconcile=all (USD+AIG)
# Idempotency-Key / body.idempotencyKey en bonos y claim · límite claim/min: GENESIS_REWARD_CLAIM_RPM (default 15)
# GENESIS_REWARD_CLAIM_RPM=15
# Admin bonos auditados: POST /api/admin/genesis/rewards/bonus/direct|binary { userId, amount, idempotencyKey? }
# GENESIS_MIN_WITHDRAW_USD=5
# GENESIS_MINING_CLAIM_MIN_USD=10
