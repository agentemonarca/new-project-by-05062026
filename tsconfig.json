{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "useDefineForClassFields": true,
    "allowImportingTsExtensions": true,
    "allowJs": true,
    "checkJs": false,
    "baseUrl": ".",
    "paths": {
      "@ai-genesis/types": ["packages/types/src"],
      "@ai-genesis/types/*": ["packages/types/src/*"],
      "@ai-genesis/config": ["packages/config/src"],
      "@ai-genesis/config/*": ["packages/config/src/*"],
      "@ai-genesis/state": ["packages/state/src"],
      "@ai-genesis/state/*": ["packages/state/src/*"],
      "@ai-genesis/ui": ["packages/ui/src"],
      "@ai-genesis/ui/*": ["packages/ui/src/*"],
      "@ai-genesis/bridge": ["packages/bridge/src"],
      "@ai-genesis/bridge/*": ["packages/bridge/src/*"]
    }
  },
  "include": ["packages/*/src/**/*"],
  "exclude": ["node_modules", "**/dist", "**/build"]
}
